# Dependencies
node_modules/
package-lock.json
yarn.lock
pnpm-lock.yaml

# Environment & secrets — NEVER commit these
.env
.env.local
.env.*.local
*.pem
*.key
secrets/

# Vercel
.vercel/

# OS
.DS_Store
Thumbs.db
desktop.ini

# Editors
.vscode/
.idea/
*.swp
*.swo

# Build artefacts (generated outputs only — keep source configs tracked)
dist/
.cache/
*.log

# build/ contains source configs (tailwind.input.css, adsense-slots.json, README.md,
# cjk-charset.txt) that we DO want tracked. Ignore only the heavy / generated bits:
build/fonts-source/
build/output/
build/.lighthouseci/

# Lighthouse CI run output
.lighthouseci/

# Tailwind / Pagefind / fonts generated output
assets/tw.css
assets/fonts/*.subset.woff2
assets/fonts/fonts.css
_pagefind/

# .bak files left by switch_to_static_css.py
*.bak
